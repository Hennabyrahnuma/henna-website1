                <a href="https://www.facebook.com/share/1DnpLkbSn5/" target="_blank"><strong>আমাদের পেজ দেখুন</strong></a>
            </div>
            <div class="contact-card">
                <div class="contact-icon">📱</div>
                <h3>সরাসরি যোগাযোগ</h3>
                <a href="tel:+880197380194"><strong>+880 197380194</strong></a>
            </div>
        </div>
    </section>

    <footer>
        <h3 style="margin-bottom: 20px;">🌿 Henna By Rahnuma 🌿</h3>
        <p>© 2024 Henna By Rahnuma | শতভাগ অর্গানিক মেহেদী</p>
    </footer>

    <script>
        function orderNow(productName) {
            const phoneNumber = '880197380194';
            const message = `আমি ${productName} এর একটি অর্ডার দিতে চাই।`;
            const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(message)}`;
            window.open(whatsappUrl, '_blank');
        }
    </script>
</body>
</html>
