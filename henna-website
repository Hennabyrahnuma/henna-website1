                <button class="order-btn" onclick="orderNow('23g - 130 টাকা')">অর্ডার করুন</button>
            </div>
        </div>
    </section>

    <section class="features" id="features">
        <h2 class="section-title">কেন আমাদের বেছে নিবেন?</h2>
        <div class="features-grid">
            <div class="feature-item">
                <div class="feature-icon">🌿</div>
                <h3>১০০% অর্গানিক</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🎨</div>
                <h3>গভীর রঙ</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">🛡️</div>
                <h3>নিরাপদ ও কার্যকর</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">💚</div>
                <h3>পরিবেশবান্ধব</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">⚡</div>
                <h3>দ্রুত ডেলিভারি</h3>
            </div>
            <div class="feature-item">
                <div class="feature-icon">💰</div>
                <h3>সাশ্রয়ী মূল্য</h3>
            </div>
        </div>
    </section>

    <section class="about" id="about">
        <div>
            <h2>আমাদের গল্প</h2>
            <p>Henna By Rahnuma একটি ছোট্ট স্বপ্ন থেকে শুরু হয়েছিল - প্রকৃতির বিশুদ্ধতা আপনার কাছে পৌঁছে দেওয়া।</p>
            <p>আমরা সবচেয়ে ভালো অর্গানিক উপাদান দিয়ে আমাদের মেহেদী তৈরি করি। প্রতিটি পণ্য যত্ন এবং ভালোবাসা দিয়ে প্যাকেজ করা হয়।</p>
            <p><strong>আমাদের লক্ষ্য:</strong> প্রতিটি উৎসবকে আরও সুন্দর করে তোলা। ✨</p>
        </div>
    </section>

    <section class="contact" id="contact">
        <h2 class="section-title">আমাদের সাথে যোগাযোগ করুন</h2>
        <div class="contact-methods">
