                <p class="product-size">17 গ্রাম</p>
                <div class="product-price">৭০ ৳</div>
                <button class="order-btn" onclick="orderNow('17g - 70 টাকা')">অর্ডার করুন</button>
            </div>
            <div class="product-card">
                <div class="product-icon">⭐</div>
                <h3>মিডিয়াম সাইজ</h3>
                <p class="product-size">20 গ্রাম</p>
                <div class="product-price">১০০ ৳</div>
                <button class="order-btn" onclick="orderNow('20g - 100 টাকা')">অর্ডার করুন</button>
            </div>
            <div class="product-card">
                <div class="product-icon">👑</div>
                <h3>প্রিমিয়াম সাইজ</h3>
                <p class="product-size">23 গ্রাম</p>
